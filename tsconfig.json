{
  "include": ["src/dom/**/*.ts"],
  "compilerOptions": {
	"declaration": false,
	"esModuleInterop": true,
	"experimentalDecorators": true,
	"preserveConstEnums": true,
	"module": "ESNext",
	"moduleResolution": "bundler",
	"sourceMap": false,
	"strict": true,
	"target": "ESNext",
	"lib": ["ESNext","DOM"],
	"allowJs": true,
	"skipDefaultLibCheck": true,
	"skipLibCheck": true
  }
}
